<!-- Hero + summary -->
<div class="flight-exp-page">
  <section class="flight-exp-hero">
    <div class="flight-exp-hero__main">
      <p class="flight-exp-eyebrow">Flight expenses</p>
      <h1 class="flight-exp-title" id="flight-title">Flight <%= flight.flt_number %></h1>
      <div class="flight-exp-chips" id="flight-meta-chips" aria-label="Flight legs"></div>
      <p class="flight-exp-sub" id="flight-info-description">Loading flight information…</p>
    </div>
    <div class="flight-exp-hero__actions">
      <button type="button" class="btn flight-exp-back-btn" id="backBtn">
        <i class="bi bi-arrow-left"></i>
        Back to Flights
      </button>
    </div>
  </section>

  <div class="flight-exp-summary-bar" id="flight-exp-summary-bar" style="display: none;" role="status">
    <div class="flight-exp-summary-bar__item">
      <span class="flight-exp-summary-bar__label">Lines</span>
      <span class="flight-exp-summary-bar__value" data-line-count>0</span>
    </div>
    <div class="flight-exp-summary-bar__divider" aria-hidden="true"></div>
    <div class="flight-exp-summary-bar__item flight-exp-summary-bar__item--primary">
      <span class="flight-exp-summary-bar__label">Estimated total (USD)</span>
      <span class="flight-exp-summary-bar__value" data-grand-usd>$0.00</span>
    </div>
    <p class="flight-exp-summary-bar__hint">Amounts in other currencies converted for reference (same rules as the rest of the app).</p>
  </div>

  <!-- Loading -->
  <div id="loading-spinner" class="flight-exp-loading">
    <div class="flight-exp-loading__card">
      <div class="spinner-border text-primary flight-exp-spinner" role="status">
        <span class="visually-hidden">Loading…</span>
      </div>
      <p class="flight-exp-loading__text">Loading expenses for this flight…</p>
    </div>
  </div>

  <!-- Content -->
  <div id="content-container" class="flight-exp-content" style="display: none;">
    <div id="expenses-sections-container" class="flight-exp-categories"></div>
  </div>

  <!-- Empty state -->
  <div id="no-data-message" class="flight-exp-empty" style="display: none;">
    <div class="flight-exp-empty__card">
      <i class="bi bi-inbox flight-exp-empty__icon" aria-hidden="true"></i>
      <h2 class="flight-exp-empty__title">No expenses linked</h2>
      <p class="flight-exp-empty__text">There are no expense lines tied to this flight number yet.</p>
      <button type="button" class="btn flight-exp-back-btn" id="emptyBackBtn">
        <i class="bi bi-arrow-left"></i>
        Back to Flights
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  loadFlightExpenses();

  document.getElementById('backBtn').addEventListener('click', function() {
    window.location.href = '/flights';
  });
  const emptyBack = document.getElementById('emptyBackBtn');
  if (emptyBack) {
    emptyBack.addEventListener('click', function() {
      window.location.href = '/flights';
    });
  }
});

async function loadFlightExpenses() {
  try {
    const flightNumber = '<%= flight.flt_number %>';
    const encodedFlightNumber = encodeURIComponent(flightNumber);
    const response = await apiRequest(`/api/flights/${encodedFlightNumber}/expenses`);
    const flightData = await response.json();
    
    document.getElementById('loading-spinner').style.display = 'none';

    updateFlightInfoDescription(flightData.flights || []);
    updateFlightMetaChips(flightData.flights || []);

    const summaryBar = document.getElementById('flight-exp-summary-bar');
    if (summaryBar) summaryBar.style.display = 'none';

    if (!flightData || !flightData.expenses || flightData.expenses.length === 0) {
      document.getElementById('no-data-message').style.display = 'flex';
      return;
    }

    document.getElementById('content-container').style.display = 'block';

    const groupedExpenses = groupExpensesByCategory(flightData.expenses);
    renderExpenseCards(groupedExpenses);
    
  } catch (error) {
    console.error('Error loading flight expenses:', error);
    document.getElementById('loading-spinner').style.display = 'none';
    document.getElementById('no-data-message').style.display = 'flex';
  }
}

function updateFlightInfoDescription(flights) {
  const descriptionElement = document.getElementById('flight-info-description');
  
  if (!flights || flights.length === 0) {
    descriptionElement.textContent = 'No flight information available';
    return;
  }
  
  const sortedFlights = [...flights].sort((a, b) => {
    const dateA = new Date(a.flt_date);
    const dateB = new Date(b.flt_date);
    return dateA - dateB;
  });
  
  // Format flights info
  const flightInfoParts = sortedFlights.map(flight => {
    const date = new Date(flight.flt_date);
    const formattedDate = date.toLocaleDateString('en-US', { 
      year: 'numeric', 
      month: 'short', 
      day: 'numeric' 
    });
    const route = `${flight.flt_dep} → ${flight.flt_arr}`;
    return `${formattedDate} • ${route}`;
  });
  
  descriptionElement.textContent =
    flightInfoParts.length > 1
      ? `${sortedFlights.length} legs: ` + flightInfoParts.join(' · ')
      : flightInfoParts[0] || '';
}

function updateFlightMetaChips(flights) {
  const chips = document.getElementById('flight-meta-chips');
  if (!chips) return;
  chips.innerHTML = '';
  if (!flights || flights.length === 0) return;

  const sorted = [...flights].sort(
    (a, b) => new Date(a.flt_date) - new Date(b.flt_date)
  );

  sorted.forEach(f => {
    const date = new Date(f.flt_date);
    const dStr = date.toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    });
    const span = document.createElement('span');
    span.className = 'flight-exp-chip';
    span.innerHTML = `<i class="bi bi-calendar3" aria-hidden="true"></i> ${dStr}<span class="flight-exp-chip__route">${f.flt_dep || '—'} <i class="bi bi-arrow-right" aria-hidden="true"></i> ${f.flt_arr || '—'}</span>`;
    chips.appendChild(span);
  });
}

function formatUsd(value) {
  return '$' + Number(value).toLocaleString('en-US', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}

function formatOriginalAmount(amount, currency) {
  const n = parseFloat(amount) || 0;
  const cur = (currency || 'USD').toUpperCase();
  return (
    n.toLocaleString('en-US', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }) +
    ' ' +
    cur
  );
}

function getCategoryVisual(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('ground handling'))
    return { icon: 'bi-building', accent: '217 91% 45%' };
  if (c.includes('fuel'))
    return { icon: 'bi-fuel-pump', accent: '32 95% 44%' };
  if (c.includes('disbursement'))
    return { icon: 'bi-percent', accent: '262 83% 58%' };
  if (c.includes('catering'))
    return { icon: 'bi-cup-hot', accent: '350 89% 60%' };
  return { icon: 'bi-receipt', accent: '215 16% 47%' };
}

function groupExpensesByCategory(expenses) {
  const groups = {};
  
  expenses.forEach(expense => {
    const category = getExpenseCategory(expense);
    
    if (!groups[category]) {
      groups[category] = [];
    }
    
    groups[category].push(expense);
  });
  
  return groups;
}

function getExpenseCategory(expense) {
  const type = (expense.exp_type || '').toLowerCase();
  const subtype = (expense.exp_subtype || '').trim();
  
  // Map expense types to categories
  if (type.includes('ground handling')) {
    if (subtype && subtype.toLowerCase().includes('departure')) {
      return 'Ground Handling - Departure';
    }
    if (subtype && subtype.toLowerCase().includes('arrival')) {
      return 'Ground Handling - Arrival';
    }
    return 'Ground Handling';
  }
  
  if (type.includes('fuel')) {
    return 'Fuel';
  }
  
  if (type.includes('disbursement')) {
    return 'Disbursement Fee';
  }
  
  if (type.includes('catering') || type.includes('food')) {
    return 'Catering';
  }
  
  // All other categories go to "Other Charges"
  if (type.includes('navigation') || type.includes('enroute')) {
    return 'Other Charges';
  }
  
  if (type.includes('overflight')) {
    return 'Other Charges';
  }
  
  if (type.includes('landing')) {
    return 'Other Charges';
  }
  
  if (type.includes('flight planning')) {
    return 'Other Charges';
  }
  
  // Default: Other Charges
  return 'Other Charges';
}

function sortCategoryKeys(groupedExpenses) {
  const categoryOrder = [
    'Ground Handling',
    'Ground Handling - Departure',
    'Ground Handling - Arrival',
    'Fuel',
    'Disbursement Fee',
    'Catering',
    'Other Charges',
  ];
  const allCategories = Object.keys(groupedExpenses);
  const sortedCategories = [];
  const usedCategories = new Set();

  categoryOrder.forEach(orderedCategory => {
    if (allCategories.includes(orderedCategory) && !usedCategories.has(orderedCategory)) {
      sortedCategories.push(orderedCategory);
      usedCategories.add(orderedCategory);
    } else {
      const matchingCategory = allCategories.find(
        cat =>
          !usedCategories.has(cat) &&
          (cat.toLowerCase().includes(orderedCategory.toLowerCase()) ||
            orderedCategory.toLowerCase().includes(cat.toLowerCase()))
      );
      if (matchingCategory) {
        sortedCategories.push(matchingCategory);
        usedCategories.add(matchingCategory);
      }
    }
  });

  allCategories.forEach(category => {
    if (!usedCategories.has(category)) {
      sortedCategories.push(category);
      usedCategories.add(category);
    }
  });
  return sortedCategories;
}

function renderExpenseCards(groupedExpenses) {
  const container = document.getElementById('expenses-sections-container');
  container.innerHTML = '';

  const sortedCategories = sortCategoryKeys(groupedExpenses);
  let grandUSD = 0;
  let lineCount = 0;

  sortedCategories.forEach(category => {
    const expenses = groupedExpenses[category];
    const { table, totalUSD, count } = createExpensesTable(expenses, category);
    grandUSD += totalUSD;
    lineCount += count;

    const visual = getCategoryVisual(category);
    const card = document.createElement('article');
    card.className = 'flight-cat-card';
    card.style.setProperty('--cat-accent', visual.accent);

    const header = document.createElement('header');
    header.className = 'flight-cat-card__header';
    header.innerHTML = `
      <div class="flight-cat-card__icon-wrap" aria-hidden="true">
        <i class="bi ${visual.icon}"></i>
      </div>
      <div class="flight-cat-card__titles">
        <h2 class="flight-cat-card__title">${category}</h2>
        <p class="flight-cat-card__meta">${count} line${count === 1 ? '' : 's'} · ${formatUsd(totalUSD)} <span class="flight-cat-card__meta-hint">(USD ref.)</span></p>
      </div>
    `;

    const body = document.createElement('div');
    body.className = 'flight-cat-card__body';
    const wrap = document.createElement('div');
    wrap.className = 'flight-exp-table-wrap';
    wrap.appendChild(table);
    body.appendChild(wrap);

    card.appendChild(header);
    card.appendChild(body);
    container.appendChild(card);
  });

  const summaryBar = document.getElementById('flight-exp-summary-bar');
  if (summaryBar) {
    summaryBar.style.display = 'flex';
    const lc = summaryBar.querySelector('[data-line-count]');
    const gu = summaryBar.querySelector('[data-grand-usd]');
    if (lc) lc.textContent = String(lineCount);
    if (gu) gu.textContent = formatUsd(grandUSD);
  }
}

function createExpensesTable(expenses, category) {
  const table = document.createElement('table');
  table.className = 'flight-exp-table';

  const thead = document.createElement('thead');
  thead.innerHTML = `
    <tr>
      <th scope="col">Type</th>
      <th scope="col">Amount</th>
      <th scope="col">Place</th>
      <th scope="col">Subtype</th>
      <th scope="col">Invoice</th>
      <th scope="col">Notes</th>
    </tr>
  `;
  table.appendChild(thead);

  const tbody = document.createElement('tbody');
  let totalUSD = 0;
  const currencyTotals = {};

  expenses.forEach(expense => {
    const amount = parseFloat(expense.exp_amount) || 0;
    const currency = expense.exp_currency || 'USD';
    const expenseDate = getExpenseDate(expense);
    const amountInUSD = convertToUSD(amount, currency, expenseDate);
    totalUSD += amountInUSD;

    if (!currencyTotals[currency]) currencyTotals[currency] = 0;
    currencyTotals[currency] += amount;

    const invoiceNumber = expense.invoices?.inv_number || '—';
    const invoiceId = expense.invoices?.id || null;
    const place = expense.exp_place || '';
    const fuelQuantity = expense.exp_fuel_quan;
    const fuelProvider = expense.exp_fuel_provider || '';
    const comments = expense.exp_comments || '';
    const subtype = expense.exp_subtype || '';
    const expType = expense.exp_type || '';

    const invoiceLink = invoiceId
      ? `<a href="/invoices/${invoiceId}" class="flight-exp-invoice-pill" target="_blank" rel="noopener">${invoiceNumber}</a>`
      : `<span class="flight-exp-invoice-muted">${invoiceNumber}</span>`;

    let combinedNotes = comments;
    const fuelParts = [];
    if (fuelQuantity != null && fuelQuantity !== '')
      fuelParts.push(`Fuel: ${fuelQuantity} L`);
    if (fuelProvider) fuelParts.push(fuelProvider);
    if (fuelParts.length) {
      combinedNotes = comments
        ? `${comments}<br><span class="flight-exp-fuel-meta">${fuelParts.join(' · ')}</span>`
        : `<span class="flight-exp-fuel-meta">${fuelParts.join(' · ')}</span>`;
    }

    const row = document.createElement('tr');
    row.className = 'flight-exp-row';
    row.innerHTML = `
      <td class="flight-exp-cell flight-exp-cell--type">${expType || '—'}</td>
      <td class="flight-exp-cell flight-exp-cell--amount">
        <span class="flight-exp-amt-main">${formatOriginalAmount(amount, currency)}</span>
        <span class="flight-exp-amt-usd">≈ ${formatUsd(amountInUSD)}</span>
      </td>
      <td class="flight-exp-cell">${place || '—'}</td>
      <td class="flight-exp-cell">${subtype || '—'}</td>
      <td class="flight-exp-cell flight-exp-cell--invoice">${invoiceLink}</td>
      <td class="flight-exp-cell flight-exp-cell--notes">${combinedNotes || '—'}</td>
    `;
    tbody.appendChild(row);
  });

  const currencyTotalsText = Object.keys(currencyTotals)
    .sort()
    .map(c => {
      const total = currencyTotals[c];
      return `${total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${c}`;
    })
    .join(' · ');

  const totalRow = document.createElement('tr');
  totalRow.className = 'flight-exp-table__total';
  totalRow.innerHTML = `
    <td class="flight-exp-cell flight-exp-cell--total-label" colspan="2">
      <span class="flight-exp-total-word">Category total</span>
      <span class="flight-exp-total-usd">${formatUsd(totalUSD)}</span>
      <span class="flight-exp-total-native">${currencyTotalsText}</span>
    </td>
    <td class="flight-exp-cell" colspan="4"></td>
  `;
  tbody.appendChild(totalRow);

  table.appendChild(tbody);
  return { table, totalUSD, count: expenses.length };
}

function getExpenseDate(expense) {
  if (expense.flights?.flt_date) return new Date(expense.flights.flt_date);
  if (expense.exp_period_start) return new Date(expense.exp_period_start);
  return new Date();
}

function getAEDToUSDRate(asOfDate) {
  return asOfDate < new Date('2025-11-01') ? 3.6735 : 3.6725;
}

function convertToUSD(amount, currency, asOfDate) {
  if (!amount) return 0;
  
  const numAmount = parseFloat(amount);
  const aedToUsd = getAEDToUSDRate(asOfDate || new Date());
  const eurToUsd = 1.16;
  
  switch (currency?.toUpperCase()) {
    case 'USD':
      return numAmount;
    case 'AED':
      return numAmount / aedToUsd;
    case 'EUR':
      return numAmount * eurToUsd;
    default:
      return numAmount;
  }
}
</script>

